<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="1" author="oleh">
        <sql>CREATE TABLE test_identity_by_default(id_by_default INTEGER GENERATED BY DEFAULT AS IDENTITY (100, 5) NOT NULL);</sql>
        <sql>CREATE TABLE test_identity_always(id_always INTEGER GENERATED ALWAYS AS IDENTITY (100, 5) NOT NULL);</sql>
        <sql>CREATE TABLE test_identity_simple(id_simple INTEGER IDENTITY(100, 5) NOT NULL);</sql>
        <createTable tableName="test_table">
            <column name="test_id" type="int">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="test_column" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <sql>DROP TABLE test_identity_by_default;</sql>
            <sql>DROP TABLE test_identity_always;</sql>
            <sql>DROP TABLE test_identity_simple;</sql>
            <dropTable tableName="test_table"/>
        </rollback>
    </changeSet>
</databaseChangeLog>